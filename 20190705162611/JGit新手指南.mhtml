#main-message {
  text-align: center;
}

.error-title {
  font-size: 22px;
  color: #000000;
  margin-bottom: 0;
}

.error-code {
  font-size: 12px;
  color: #a6a6a6;
  display: block;
  margin-top: 10px;
  opacity: 1;
}

button {
  float: none;
  width: 125px;
  height: 36px;
  -webkit-user-select: none;
  border: 0;
  border-radius: 0px;
  box-sizing: border-box;
  color: #fff;
  cursor: pointer;
  font-size: 14px;
  padding: 0px;
  transition: none;
  outline: none;
  font-family: "Microsoft Yahei";
}

#buttons {
  margin-top: 18px;
  padding: 0px;
}

#control-buttons {
  text-align: center;
}

